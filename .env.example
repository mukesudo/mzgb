# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# ── Groq (free at https://console.groq.com) ──────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Google Gemini (free at https://aistudio.google.com) ──────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── GitHub (token from https://github.com/settings/tokens) ─────────────────
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=your_username/your_repo_name

# ── Model selection (optional overrides) ─────────────────────────────────────
# Which model each agent uses. Defaults are set in agents/llm.py.
# GROQ_MODEL=llama-3.1-70b-versatile
# GEMINI_MODEL=gemini-1.5-flash
